{
  "name": "appsec-sidecar-vscode",
  "displayName": "AppSec Sidecar",
  "description": "VS Code extension scaffold with GitHub API and Postgres health checks.",
  "version": "0.0.1",
  "publisher": "your-publisher-id",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:appsecSidecar.configureGitHubPat",
    "onCommand:appsecSidecar.checkGitHubApi",
    "onCommand:appsecSidecar.configurePostgres",
    "onCommand:appsecSidecar.checkPostgres",
    "onCommand:appsecSidecar.viewRepoInventory",
    "onCommand:appsecSidecar.repoVulnFindings",
    "onCommand:appsecSidecar.clearStoredCredentials"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "appsecSidecar.configureGitHubPat",
        "title": "Configure GitHub PAT",
        "category": "AppSec Sidecar"
      },
      {
        "command": "appsecSidecar.checkGitHubApi",
        "title": "Check GitHub API",
        "category": "AppSec Sidecar"
      },
      {
        "command": "appsecSidecar.configurePostgres",
        "title": "Configure Postgres",
        "category": "AppSec Sidecar"
      },
      {
        "command": "appsecSidecar.checkPostgres",
        "title": "Check Postgres",
        "category": "AppSec Sidecar"
      },
      {
        "command": "appsecSidecar.viewRepoInventory",
        "title": "View Repo Inventory",
        "category": "AppSec Sidecar"
      },
      {
        "command": "appsecSidecar.repoVulnFindings",
        "title": "Repo Vuln Findings",
        "category": "AppSec Sidecar"
      },
      {
        "command": "appsecSidecar.clearStoredCredentials",
        "title": "Clear Stored Credentials",
        "category": "AppSec Sidecar"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run build:webview",
    "compile:extension": "tsc -p ./",
    "build:webview": "tsc -p ./tsconfig.webview.json --noEmit && vite build",
    "dev:webview": "vite --host 127.0.0.1 --open /src/webview/dev/index.html?view=findings",
    "watch": "tsc -watch -p ./",
    "watch:webview": "vite build --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "npm run compile && node ./out/test/runTest.js"
  },
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "pg": "^8.13.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "1.100.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/test-electron": "^2.5.2",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.25.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^8.0.13"
  }
}
